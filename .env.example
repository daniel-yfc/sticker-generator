# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Your Google Gemini API key
GEMINI_API_KEY=

# Port the backend proxy listens on (default: 3001)
BACKEND_PORT=3001

# Origin that the frontend is served from (used for CORS allow-list)
# Multiple origins comma-separated: http://localhost:5173,https://myapp.com
FRONTEND_ORIGIN=

# Set to 'false' to disable all generation (kill switch)
GENERATION_ENABLED=true

# Maximum number of generation calls per day (in-memory, resets at midnight UTC)
DAILY_QUOTA_LIMIT=200
